modules = ["python-3.11", "nodejs-20", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Crypto Bot"

[[workflows.workflow]]
name = "Crypto Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd crypto-bot && python main.py"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python", "crypto-bot/main.py"]
